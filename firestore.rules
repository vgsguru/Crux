rules_version = '2';

// Crux Firestore security rules.
//
// Model: Firebase Auth identifies users; roles live on users/{uid}.role.
// Trusted server functions use the Admin SDK and BYPASS these rules entirely —
// so these rules only need to gate DIRECT client reads/writes.
//
// NOTE: this is a pragmatic baseline that makes the app work with sensible
// guardrails. Before production, tighten the counter-update and recruiter-access
// paths (see inline TODOs).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }
    // Only these post fields may change on a cross-user write (like/comment/share counters).
    function onlyCounters() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['like_count', 'comment_count', 'share_count']);
    }

    // Public identity docs: anyone can read (public profile URLs work signed-out); you edit your own.
    match /profiles/{uid} {
      allow read: if true;
      allow write: if isSelf(uid);
    }

    // Username -> uid map for public profile URLs. Readable by all; a user may
    // claim a free handle (create), but can't steal/overwrite someone else's.
    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      // role is set here; a user may create/maintain their own doc. Server functions
      // handle privileged role changes (e.g. admin) via the Admin SDK.
      allow write: if isSelf(uid);
    }

    // Companies: public read; only the owner writes.
    match /companies/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.owner_id == request.auth.uid;
    }

    // Jobs: public read; recruiter who created it writes.
    match /jobs/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.created_by == request.auth.uid;
      // Owner edits freely; any signed-in user may bump like/comment/share counters.
      allow update: if signedIn() && (resource.data.created_by == request.auth.uid || onlyCounters());
      allow delete: if signedIn() && resource.data.created_by == request.auth.uid;
    }

    // Feed posts: read by all; author creates/edits/deletes; counters bumpable by anyone.
    match /posts/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update: if signedIn() && (resource.data.author_id == request.auth.uid || onlyCounters());
      allow delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /post_likes/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }
    match /post_comments/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }
    match /post_shares/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
    }

    // Applications: applicant owns their row. Recruiter access to applications for
    // their jobs is served by server functions (Admin SDK). The recruiter pipeline
    // also reads directly, so allow read when you own the application OR you own the
    // company behind the job.
    // TODO: the recruiter read below does 2 get()s per doc; acceptable for now.
    match /applications/{id} {
      allow read: if signedIn() && (
        resource.data.applicant_id == request.auth.uid ||
        get(/databases/$(database)/documents/companies/$(
          get(/databases/$(database)/documents/jobs/$(resource.data.job_id)).data.company_id
        )).data.owner_id == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.applicant_id == request.auth.uid;
      allow update: if signedIn() && resource.data.applicant_id == request.auth.uid;
    }

    // Interviews, scoring artifacts: written by server functions only.
    match /interviews/{id} {
      allow read: if signedIn();
      allow write: if false; // server-only (Admin SDK)
    }

    // Portable proof-of-skill credentials — readable by anyone signed in (shown on
    // profiles), written only by server functions when an interview is scored.
    match /credentials/{id} {
      allow read: if true; // shown on public profiles
      allow write: if false; // server-only (Admin SDK)
    }

    // Notifications: recipient reads/marks read; created by server functions.
    match /notifications/{id} {
      allow read, update: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    match /saved_jobs/{id} {
      allow read, write: if signedIn() && request.resource.data.user_id == request.auth.uid;
    }

    // Company follows: anyone signed in can read (to show follower state); you create/delete your own.
    match /follows/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    // Recruiter-owned config collections.
    match /question_bank/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.owner_id == request.auth.uid;
    }
    match /message_templates/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.owner_id == request.auth.uid;
    }
    match /interview_templates/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.owner_id == request.auth.uid;
    }
    match /interview_template_questions/{id} {
      allow read: if signedIn();
      allow write: if signedIn(); // ownership enforced via template in server fns
    }

    // Verification + audit: read for signed-in (admin UI gates further); writes server-only.
    match /company_verifications/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.requested_by == request.auth.uid;
      allow update: if isAdmin();
    }
    match /role_audit/{id} {
      allow read: if isAdmin();
      allow write: if false; // server-only
    }
    // Immutable AI-scoring audit trail (fairness/defensibility). Server-only writes.
    match /score_audits/{id} {
      allow read: if isAdmin();
      allow write: if false; // server-only (Admin SDK)
    }

    // Verified recruitment claims: a recruiter tags someone they hired; the hired
    // member must approve before it counts. Recruiter creates; member approves/rejects.
    match /recruitment_claims/{id} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.recruiter_id == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if signedIn() && resource.data.member_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decided_at']);
      allow delete: if signedIn() && resource.data.recruiter_id == request.auth.uid;
    }

    // User-submitted content reports (trust & safety).
    match /reports/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.reported_by == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    match /application_messages/{id} {
      allow read: if signedIn();
      allow write: if false; // server-only
    }
  }
}
