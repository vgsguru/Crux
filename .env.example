# ─────────────────────────────────────────────────────────────────────────────
# Crux environment variables. Copy to `.env` and fill in real values.
# NEVER commit a real `.env`. Anything prefixed VITE_ is exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (client SDK — safe to expose) ──────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (server only) ────────────────────────────────────────────
# Required for server functions to read/write Firestore and Storage.
# Provide ONE of:
#   1) FIREBASE_SERVICE_ACCOUNT = the full service-account JSON on a single line, or
#   2) GOOGLE_APPLICATION_CREDENTIALS = absolute path to that JSON file (ADC).
# When deployed on Google Cloud / Firebase, ambient credentials are used and
# neither is needed. Token verification works with just the project id above.
FIREBASE_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Optional overrides (default to the VITE_ values above):
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=

# ── AI providers (server only) ──────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# ── Email (server only) ─────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Text-to-speech: Chatterbox (self-hosted) (server only) ───────────────────
# Optional — powers the live-interview AI voice. Without a reachable endpoint, the
# interview shows questions on-screen and skips audio. Run Chatterbox (e.g. the
# chatterbox-tts-api wrapper, OpenAI-speech compatible) and point this at it.
CHATTERBOX_API_URL=http://localhost:4123/v1/audio/speech
CHATTERBOX_API_KEY=
CHATTERBOX_VOICE=default
